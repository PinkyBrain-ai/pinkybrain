<service>
  <id>PinkyBrain</id>
  <name>PinkyBrain P2P AI Network</name>
  <description>PinkyBrain — Lightweight P2P distributed AI network</description>
  <executable>C:\PinkyBrain\python\python.exe</executable>
  <arguments>C:\PinkyBrain\app\src\pinkybrain_v5.py --config C:\PinkyBrain\data\config\node.json</arguments>
  <logpath>C:\PinkyBrain\data\logs\service</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <onfailure action="restart" delay="120 sec"/>
  <startmode>Automatic</startmode>
  <env name="PINKYBRAIN_HOME" value="C:\PinkyBrain"/>
  <env name="PYTHONPATH" value="C:\PinkyBrain\app\src;C:\PinkyBrain\python\Lib"/>
  <pidfile>C:\PinkyBrain\data\pinkybrain.pid</pidfile>
  <stopparentprocessfirst>true</stopparentprocessfirst>
</service>